{
  "name": "Microsoft Teams MCP",
  "version": "2.0.0",
  "description": "Send messages, create meetings, manage channels, handle app installations, and orchestrate proactive notifications via the Microsoft Graph API",
  "author": "Claude-m",
  "mcpServer": {
    "command": "node",
    "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
    "env": {
      "MICROSOFT_CLIENT_ID": "${MICROSOFT_CLIENT_ID}",
      "MICROSOFT_CLIENT_SECRET": "${MICROSOFT_CLIENT_SECRET}",
      "MICROSOFT_TENANT_ID": "${MICROSOFT_TENANT_ID}",
      "MICROSOFT_ACCESS_TOKEN": "${MICROSOFT_ACCESS_TOKEN}"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "capabilities": {
    "tools": [
      "teams_list_teams",
      "teams_list_channels",
      "teams_send_message",
      "teams_create_meeting",
      "teams_list_channel_messages",
      "teams_reply_to_message",
      "teams_list_members",
      "teams_list_apps",
      "teams_send_adaptive_card",
      "teams_list_chats",
      "teams_send_chat_message",
      "teams_create_subscription"
    ]
  },
  "requiredScopes": [
    "ChannelMessage.Send",
    "ChannelMessage.Read.All",
    "Chat.ReadWrite",
    "ChatMessage.Send",
    "OnlineMeetings.ReadWrite",
    "Team.ReadBasic.All",
    "TeamMember.Read.All",
    "TeamsAppInstallation.ReadForTeam",
    "Subscription.Read.All"
  ],
  "category": "productivity",
  "tags": ["microsoft", "teams", "collaboration", "meetings", "bots", "adaptive-cards", "notifications", "subscriptions"]
}
