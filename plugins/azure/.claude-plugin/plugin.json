{
  "name": "microsoft-azure-mcp",
  "version": "1.0.0",
  "description": "Inspect subscriptions, resource groups, and resources via MCP.",
  "author": {
    "name": "Markus Ahling"
  },
  "license": "MIT",
  "homepage": "https://github.com/markus41/Claude-m/blob/main/plugins/azure/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/markus41/Claude-m"
  },
  "keywords": [
    "microsoft",
    "azure",
    "infrastructure"
  ],
  "mcpServers": {
    "microsoft-azure-mcp": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
      "env": {
        "MICROSOFT_CLIENT_ID": "${MICROSOFT_CLIENT_ID}",
        "MICROSOFT_CLIENT_SECRET": "${MICROSOFT_CLIENT_SECRET}",
        "MICROSOFT_TENANT_ID": "${MICROSOFT_TENANT_ID}",
        "MICROSOFT_ACCESS_TOKEN": "${MICROSOFT_ACCESS_TOKEN}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
