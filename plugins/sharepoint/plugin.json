{
  "name": "Microsoft SharePoint MCP",
  "version": "1.0.0",
  "description": "List, upload, and download files from SharePoint sites via the Microsoft Graph API",
  "author": "Claude-m",
  "mcpServer": {
    "command": "node",
    "args": ["${PLUGIN_DIR}/../../dist/index.js"],
    "env": {
      "MICROSOFT_CLIENT_ID": "${MICROSOFT_CLIENT_ID}",
      "MICROSOFT_CLIENT_SECRET": "${MICROSOFT_CLIENT_SECRET}",
      "MICROSOFT_TENANT_ID": "${MICROSOFT_TENANT_ID}",
      "MICROSOFT_ACCESS_TOKEN": "${MICROSOFT_ACCESS_TOKEN}"
    }
  },
  "capabilities": {
    "tools": [
      "sharepoint_list_sites",
      "sharepoint_list_files",
      "sharepoint_upload_file",
      "sharepoint_download_file"
    ]
  },
  "requiredScopes": [
    "Sites.ReadWrite.All",
    "Files.ReadWrite.All"
  ],
  "category": "productivity",
  "tags": ["microsoft", "sharepoint", "files", "documents"]
}
